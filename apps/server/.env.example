PORT=8080
CORS_ORIGIN=http://localhost:3000
BATCH_SIZE=10
MAX_FILE_SIZE_MB=5
# Batches processed in parallel. Free-tier Groq/OpenRouter/Gemini keys have low
# tokens-per-minute budgets — keep this at 1 for those; Anthropic direct can go higher.
AI_CONCURRENCY=1

# AI provider: this deployment uses OpenRouter (Claude Haiku) instead of a direct
# Anthropic key. Set AI_TRANSPORT=anthropic + ANTHROPIC_API_KEY to switch back to the
# assignment-spec default (direct @anthropic-ai/sdk calls), or AI_TRANSPORT=groq /
# AI_TRANSPORT=gemini for the other dev-tested paths.
AI_TRANSPORT=openrouter
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Free-tier credits are small and OpenRouter reserves prompt+max_tokens upfront —
# keep this well under your account's affordable budget, or a 402 will fire before
# generation even starts.
OPENROUTER_MAX_TOKENS=2500

# Only needed if AI_TRANSPORT=groq
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=3000

# Only needed if AI_TRANSPORT=gemini
GEMINI_API_KEY=xxxx
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192

# Only needed if AI_TRANSPORT=anthropic
ANTHROPIC_API_KEY=
